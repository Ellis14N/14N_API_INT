# 14N API Integration configuration
# Copy this file to .env and fill in values for your deployment.

# ACLED credentials
ACLED_USERNAME=your_acled_username
ACLED_PASSWORD=your_acled_password

# OpenSky credentials
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password

# AeroDataBox via RapidAPI
AERODATA_API_KEY=your_aerodatabox_rapidapi_key

# AviationStack credentials
AVIATIONSTACK_API_KEY=your_aviationstack_api_key

# Railway port binding
PORT=8000
